# ── Dependencies ──────────────────────────────────────────────
node_modules/

# ── Environment variables ──────────────────────────────────────
.env
.env.local
.env.*.local

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── apnaGit VCS ────────────────────────────────────────────────
# Local .apnaGit repos created when running VCS CLI from this directory
.apnaGit/

# Leftover artifact written to cwd on `revert` — not a config file
commit.json

# ── AWS ────────────────────────────────────────────────────────
# Use env vars or AWS CLI profile — never commit credentials
.aws/
aws-credentials*

# ── OS files ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor directories ─────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
